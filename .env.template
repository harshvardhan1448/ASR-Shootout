# ============================================================
# ASR Benchmark - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your API credentials

# DEEPGRAM API KEY
# Sign up at: https://console.deepgram.com/
# Free tier: 50,000 minutes/month (sufficient for this benchmark)
# Required: Yes
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# OPENAI API KEY
# Sign up at: https://platform.openai.com/account/api-keys
# Note: Currently using free local Whisper model
# Required: No (Whisper runs locally without API key)
OPENAI_API_KEY=your_openai_api_key_here

# GOOGLE CLOUD SPEECH-TO-TEXT
# Setup:
# 1. Create a Google Cloud Project at: https://console.cloud.google.com
# 2. Enable Speech-to-Text API
# 3. Create Service Account with Editor role
# 4. Download JSON credentials file
# 5. Set path to credentials JSON file below
# Pricing: $0.024-0.036 per 15 seconds depending on model
# Required: No (Optional, to include in benchmark comparison)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# Optional: Recording and Output Directories
# Default: ./recordings and ./outputs
RECORDINGS_DIR=./recordings
OUTPUTS_DIR=./outputs
